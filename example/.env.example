# Copy to .env and fill in. Load before `go run`, e.g.:
#   set -a && source .env && set +a && go run .
#
# These names are for **client apps** using the SDK. They are not the same as
# server/worker variables such as OPS_API_BASE_URL in the ops-api repo root .env.

# Required: API key (sk_ops_...) from the developer portal, or an Auth0 access token.
OPERATIONAL_API_TOKEN=<YOUR_TOKEN>

# Optional: override the API origin. When unset, the Go SDK uses OPERATIONAL_API_BASE_URL
# from the process (if set), then DefaultPublicAPIBaseURL from defaults_gen.go in the parent module.
# OPERATIONAL_API_BASE_URL=http://127.0.0.1:8080
